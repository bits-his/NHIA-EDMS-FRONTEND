# --- Development: choose ONE style ---
#
# A) Vite proxy (default): browser calls same origin (:5173); Vite forwards to agents.
#    Axios base URLs are paths like /proxy/document — requests still hit the real
#    backend routes on ports 3000–3007 (see vite.config.ts proxy).
#
# B) Direct agent URLs: set backend .env CORS_ORIGIN=http://localhost:5173 then use:
#    VITE_DOCUMENT_URL=http://localhost:3012
#    (and matching ports for other agents). axios talks straight to each agent.
#
VITE_ORCHESTRATOR_URL=/proxy/orchestrator
VITE_AUTH_URL=/proxy/auth
# Document agent origin only — never append /documents (API paths add /documents/... in code).
VITE_DOCUMENT_URL=/proxy/document
VITE_WORKFLOW_URL=/proxy/workflow
VITE_TASK_URL=/proxy/task
VITE_AUDIT_URL=/proxy/audit
VITE_NOTIFICATION_URL=/proxy/notification
VITE_SEARCH_OCR_URL=/proxy/search

# Production / Vercel — set these in Vercel → Project → Settings → Environment Variables
# VITE_ORCHESTRATOR_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_AUTH_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_DOCUMENT_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_WORKFLOW_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_TASK_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_AUDIT_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_NOTIFICATION_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
# VITE_SEARCH_OCR_URL=https://server.brainstorm.ng/NHIA-EDMS-BACKEND
#
# On the API server .env set: CORS_ORIGIN=https://your-app.vercel.app
