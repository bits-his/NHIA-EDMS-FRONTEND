# Development — uses Vite proxy to avoid CORS (no backend CORS headers configured)
VITE_ORCHESTRATOR_URL=/proxy/orchestrator
VITE_AUTH_URL=/proxy/auth
VITE_DOCUMENT_URL=/proxy/document
VITE_WORKFLOW_URL=/proxy/workflow
VITE_TASK_URL=/proxy/task
VITE_AUDIT_URL=/proxy/audit
VITE_NOTIFICATION_URL=/proxy/notification
VITE_SEARCH_OCR_URL=/proxy/search

# Production — set these to your actual service URLs
# VITE_ORCHESTRATOR_URL=https://your-domain.com/orchestrator
# VITE_AUTH_URL=https://your-domain.com/auth
# etc.
